    LANGUAGE plpgsql
    AS $$
BEGIN
  IF TG_OP = 'INSERT' OR (TG_OP = 'UPDATE' AND NEW.id_asaas IS DISTINCT FROM OLD.id_asaas) THEN
    INSERT INTO fila_atualizacao_asaas(id_asaas) VALUES (NEW.id_asaas);
  END IF;
  RETURN NEW;
END;
$$;


