-- Name: preencher_nome_evento(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.preencher_nome_evento() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  IF NEW.curso IS NOT NULL THEN
    SELECT title INTO NEW.nome_evento_comprado
    FROM events
    WHERE id::text = NEW.curso;
  END IF;

  RETURN NEW;
END;
$$;


