-- Name: payment_tracking Allow update for service role; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow update for service role" ON public.payment_tracking FOR UPDATE TO service_role USING (true);


--
-- Name: coupons Apenas criadores podem gerenciar cupons; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Apenas criadores podem gerenciar cupons" ON public.coupons USING ((auth.uid() = created_by));


--
-- Name: events Eventos são visíveis para todos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Eventos são visíveis para todos" ON public.events FOR SELECT USING (true);


--
-- Name: Inscicao Permitir leitura pública; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Permitir leitura pública" ON public."Inscicao" FOR SELECT USING (true);


--
-- Name: roles Public can view roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Public can view roles" ON public.roles FOR SELECT TO authenticated, anon USING (true);


--
-- Name: users_roles Public can view users_roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Public can view users_roles" ON public.users_roles FOR SELECT TO authenticated, anon USING (true);


--
-- Name: roles Service role can delete roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can delete roles" ON public.roles FOR DELETE TO service_role USING (true);


--
-- Name: users_roles Service role can delete users_roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can delete users_roles" ON public.users_roles FOR DELETE TO service_role USING (true);


--
-- Name: roles Service role can insert roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can insert roles" ON public.roles FOR INSERT TO service_role WITH CHECK (true);


--
-- Name: users_roles Service role can insert users_roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can insert users_roles" ON public.users_roles FOR INSERT TO service_role WITH CHECK (true);


--
-- Name: roles Service role can update roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can update roles" ON public.roles FOR UPDATE TO service_role USING (true) WITH CHECK (true);


--
-- Name: users_roles Service role can update users_roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Service role can update users_roles" ON public.users_roles FOR UPDATE TO service_role USING (true) WITH CHECK (true);


--
-- Name: coupons Todos podem ver cupons ativos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Todos podem ver cupons ativos" ON public.coupons FOR SELECT USING ((is_active = true));


--
-- Name: users Users can insert own data; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can insert own data" ON public.users FOR INSERT WITH CHECK ((auth.uid() = id));


--
-- Name: users Users can update own data; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can update own data" ON public.users FOR UPDATE USING ((auth.uid() = id)) WITH CHECK ((auth.uid() = id));


--
-- Name: users Users can view own data; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view own data" ON public.users FOR SELECT USING ((auth.uid() = id));


--
-- Name: events Usuários podem gerenciar seus próprios eventos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Usuários podem gerenciar seus próprios eventos" ON public.events TO authenticated USING ((user_id = auth.uid())) WITH CHECK ((user_id = auth.uid()));


