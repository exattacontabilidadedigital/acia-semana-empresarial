--

CREATE TRIGGER atualiza_asaas_trigger AFTER INSERT OR UPDATE OF id_asaas ON public."Inscicao" FOR EACH ROW EXECUTE FUNCTION public.trigger_atualiza_asaas();


--
-- Name: coupons set_coupon_status; Type: TRIGGER; Schema: public; Owner: postgres
--

CREATE TRIGGER set_coupon_status BEFORE INSERT OR UPDATE ON public.coupons FOR EACH ROW EXECUTE FUNCTION public.atualizar_status_cupom();


--
-- Name: Inscicao set_order_number; Type: TRIGGER; Schema: public; Owner: postgres
--

CREATE TRIGGER set_order_number BEFORE INSERT ON public."Inscicao" FOR EACH ROW EXECUTE FUNCTION public.generate_order_number();


--
-- Name: Inscicao tg_enviar_webhook; Type: TRIGGER; Schema: public; Owner: postgres
--

CREATE TRIGGER tg_enviar_webhook AFTER INSERT OR UPDATE OF id_asaas ON public."Inscicao" FOR EACH ROW WHEN ((new.id_asaas IS NOT NULL)) EXECUTE FUNCTION public.trigger_enviar_webhook();


--
-- Name: Inscicao tg_log_idasaas_insert; Type: TRIGGER; Schema: public; Owner: postgres
--

CREATE TRIGGER tg_log_idasaas_insert AFTER INSERT ON public."Inscicao" FOR EACH ROW WHEN ((new.id_asaas IS NOT NULL)) EXECUTE FUNCTION public.log_id_asaas_trigger();


--
-- Name: Inscicao tg_log_idasaas_update; Type: TRIGGER; Schema: public; Owner: postgres
--

CREATE TRIGGER tg_log_idasaas_update AFTER UPDATE OF id_asaas ON public."Inscicao" FOR EACH ROW WHEN (((new.id_asaas IS NOT NULL) AND (new.id_asaas IS DISTINCT FROM old.id_asaas))) EXECUTE FUNCTION public.log_id_asaas_trigger();


--
-- Name: Inscicao tg_preencher_nome_evento; Type: TRIGGER; Schema: public; Owner: postgres
